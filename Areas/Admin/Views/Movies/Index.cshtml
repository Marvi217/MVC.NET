@model IEnumerable<Movie>
@using CinePlex.Models
@{
    ViewData["Title"] = "Filmy";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    int ps = ViewBag.PageSize ?? 20;
}

<style>
    .movies-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 1rem;
    }
    .movie-card {
        position: relative;
        overflow: hidden;
        aspect-ratio: 2/3;
        cursor: pointer;
        text-decoration: none;
        display: block;
    }
    .movie-poster {
        width: 100%; height: 100%;
        object-fit: cover; display: block;
    }
    .movie-poster-placeholder {
        width: 100%; height: 100%;
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        gap: .5rem;
        text-align: center; padding: .5rem;
    }
    .movie-title {
        line-height: 1.3; margin-bottom: .4rem;
        display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
    }
    .movie-meta { display: flex; gap: .3rem; flex-wrap: wrap; margin-bottom: .5rem; }
    .movie-badge { padding: .1rem .4rem; white-space: nowrap; }
    .movie-always {
        position: absolute; bottom: 0; left: 0; right: 0;
        padding: .6rem .7rem .5rem;
        background: linear-gradient(transparent, rgba(0,0,0,.82) 35%);
        color: #fff;
    }
    .genre-filter { display: flex; gap: .4rem; flex-wrap: wrap; }
    .gf-btn {
        padding: .3rem .85rem;
        text-decoration: none; white-space: nowrap;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h4 class="mb-0">Filmy <span class="text-muted fw-normal" style="font-size:.9rem;">(@Model.Count())</span></h4>
    <div class="d-flex gap-2">
        <form method="get" class="d-flex gap-2 align-items-center">
            <input type="text" name="search" value="@ViewBag.Search" class="form-control form-control-sm" placeholder="Szukaj..." style="width:170px;" />
            <input type="hidden" name="genre" value="@ViewBag.Genre" />
            <input type="hidden" name="page" value="1" />
            <select name="pageSize" class="form-select form-select-sm" style="width:75px;" onchange="this.form.submit()">
                @foreach (var n in new[]{10,20,50,100})
                {
                    <option value="@n" selected="@(ps == n ? "selected" : null)">@n</option>
                }
            </select>
            <button class="btn btn-outline-secondary btn-sm"><i class="bi bi-search"></i></button>
        </form>
        <a asp-action="Create" class="btn btn-red btn-sm"><i class="bi bi-plus-circle me-1"></i> Dodaj film</a>
    </div>
</div>

<div class="genre-filter mb-4">
    <a href="@Url.Action("Index", new { search = ViewBag.Search, page = 1, pageSize = ps })"
       class="gf-btn @(ViewBag.Genre == null ? "active" : "")">Wszystkie</a>
    @foreach (var g in Enum.GetValues<Genre>())
    {
        <a href="@Url.Action("Index", new { search = ViewBag.Search, genre = (int)g, page = 1, pageSize = ps })"
           class="gf-btn @(ViewBag.Genre?.ToString() == g.ToString() ? "active" : "")">@g</a>
    }
</div>

@if (!Model.Any())
{
    <div class="text-center text-muted py-5">
        <i class="bi bi-film" style="font-size:2.5rem;display:block;margin-bottom:.75rem;"></i>
        Brak filmów. <a asp-action="Create">Dodaj pierwszy.</a>
    </div>
}
else
{
    <div class="movies-grid">
        @foreach (var m in Model)
        {
            <a asp-action="Details" asp-route-id="@m.MovieId" class="movie-card">
                @if (!string.IsNullOrWhiteSpace(m.PosterUrl))
                {
                    <img src="@m.PosterUrl" alt="@m.Title" class="movie-poster" loading="lazy" />
                }
                else
                {
                    <div class="movie-poster-placeholder">
                        <i class="bi bi-film"></i>
                    </div>
                }
                <div class="movie-always">
                    <div class="movie-title">@m.Title</div>
                    <div class="movie-meta">
                        <span class="movie-badge">@m.Genre</span>
                        <span class="movie-badge age">@m.AgeRating</span>
                        <span class="movie-badge">@m.Duration min</span>
                    </div>
                </div>
            </a>
        }
    </div>

    
    @if (ViewBag.TotalPages > 1)
    {
        <nav class="d-flex justify-content-center align-items-center gap-3 mt-4">
            @if (ViewBag.Page > 1)
            {
                <a href="@Url.Action("Index", new { page = ViewBag.Page - 1, search = ViewBag.Search, genre = ViewBag.Genre, pageSize = ps })"
                   class="btn btn-sm btn-outline-secondary">&#8592; Poprzednia</a>
            }
            <span class="text-muted small">Strona @ViewBag.Page z @ViewBag.TotalPages</span>
            @if (ViewBag.Page < ViewBag.TotalPages)
            {
                <a href="@Url.Action("Index", new { page = ViewBag.Page + 1, search = ViewBag.Search, genre = ViewBag.Genre, pageSize = ps })"
                   class="btn btn-sm btn-outline-secondary">Następna &#8594;</a>
            }
        </nav>
    }
}
