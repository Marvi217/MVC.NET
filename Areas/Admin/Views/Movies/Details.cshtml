@model Movie
@{
    ViewData["Title"] = Model.Title;
}
<div class="row g-3">
    <div class="col-md-4">
        @if (!string.IsNullOrWhiteSpace(Model.PosterUrl))
        {
            <img src="@Model.PosterUrl" class="poster-thumb" alt="@Model.Title" />
        }
        else
        {

            <div class="poster-thumb d-flex align-items-center justify-content-center"><i class="bi bi-film" style="font-size:4rem;color:#333;"></i></div>
        }
    </div>
    <div class="col-md-8">
        <div class="card p-3">
            <h3>@Model.Title</h3>
            <table class="table table-dark-cinema mb-0">
                <tr><th>Genre</th><td><span class="badge-genre">@Model.Genre</span></td></tr>
                <tr><th>Age</th><td><span class="badge-age">@Model.AgeRating</span></td></tr>
                <tr><th>Duration</th><td>@Model.Duration min</td></tr>
                <tr><th>Released</th><td>@Model.ReleaseDate.ToString("yyyy-MM-dd")</td></tr>
                <tr><th>Director</th><td>@Model.Director?.FullName</td></tr>
                <tr><th>Trailer</th><td>@if(!string.IsNullOrWhiteSpace(Model.TrailerUrl)){
                <a href="@Model.TrailerUrl" target="_blank">Open</a>
                                }
</td></tr>
                <tr><th>Description</th><td>@Model.Description</td></tr>
            </table>
        </div>
    </div>
</div>
<div class="mt-3 d-flex gap-2">
    <a asp-action="Edit" asp-route-id="@Model.MovieId" class="btn btn-outline-warning"><i class="bi bi-pencil"></i> Edit</a>
    <a asp-action="Delete" asp-route-id="@Model.MovieId" class="btn btn-outline-danger"><i class="bi bi-trash"></i> Delete</a>
    <a href="javascript:history.back()" class="btn btn-outline-secondary">Back</a>
</div>