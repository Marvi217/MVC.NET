@model Hall
@{
    ViewData["Title"] = $"Hall #{Model.Number}";
}
<div class="card p-3">
    <h3>Hall #@Model.Number <span class="badge-hall @Model.Type.ToString().ToLower() ms-2">@(Model.Type switch { CinePlex.Models.HallType.FourD => "4DX", CinePlex.Models.HallType.ThreeD => "3D", CinePlex.Models.HallType.IMAX => "IMAX", _ => "2D" })</span></h3>
    <table class="table table-dark-cinema mb-0">
        <tr><th>Cinema</th><td>@Model.Cinema?.Name (@Model.Cinema?.City)</td></tr>
        <tr><th>Capacity</th><td>@Model.Capacity</td></tr>
        <tr><th>Screenings</th><td>@(Model.Screenings?.Count ?? 0)</td></tr>
    </table>
</div>
<div class="mt-3 d-flex gap-2">
    <a asp-action="Edit" asp-route-id="@Model.HallId" class="btn btn-outline-warning"><i class="bi bi-pencil"></i> Edit</a>
    <a asp-action="Delete" asp-route-id="@Model.HallId" class="btn btn-outline-danger"><i class="bi bi-trash"></i> Delete</a>
    <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
</div>