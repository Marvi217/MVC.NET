@model CinePlex.Models.BarSet
@using CinePlex.Models
@{
    ViewData["Title"] = "Edytuj zestaw";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    var allItems = ViewBag.AllItems as IEnumerable<BarItem> ?? Enumerable.Empty<BarItem>();
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card p-4">
            <form asp-action="Edit" method="post" enctype="multipart/form-data" id="setForm">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="BarSetId" />
                <input type="hidden" asp-for="ImageUrl" id="currentImageUrl" />

                <div class="mb-3">
                    <label asp-for="Name" class="form-label">Nazwa zestawu</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label">Opis</label>
                    <input asp-for="Description" class="form-control" />
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-6">
                        <label asp-for="Price" class="form-label">Cena zestawu (zł)</label>
                        <input asp-for="Price" type="number" step="0.01" min="0.01" class="form-control" />
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>
                    <div class="col-6">
                        <label class="form-label">Zdjęcie</label>
                        <input type="file" name="image" class="form-control" accept="image/*" id="imgInput" />
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
                {
                    <div class="mb-2">
                        <img id="imgPreview" src="@Model.ImageUrl" alt="@Model.Name"
                             style="max-height:120px;border-radius:8px;border:1px solid var(--border);" />
                    </div>
                }
                else
                {
                    <div class="mb-2" id="imgPreviewWrap" style="display:none;">
                        <img id="imgPreview" src="" style="max-height:120px;border-radius:8px;border:1px solid var(--border);" />
                    </div>
                }

                <div class="mb-4">
                    <div class="form-check">
                        <input asp-for="IsAvailable" class="form-check-input" type="checkbox" />
                        <label asp-for="IsAvailable" class="form-check-label">Dostępny w menu</label>
                    </div>
                </div>

                <hr style="border-color:var(--border);" />
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="mb-0">Produkty w zestawie</h6>
                    <button type="button" class="btn btn-sm btn-outline-secondary" id="addRow">
                        <i class="bi bi-plus"></i> Dodaj produkt
                    </button>
                </div>

                <div id="itemRows">
                    @foreach (var si in Model.Items)
                    {
                        <div class="row g-2 mb-2 item-row align-items-center">
                            <div class="col-7">
                                <select name="itemIds" class="form-select form-select-sm">
                                    <option value="0">- wybierz produkt -</option>
                                    @foreach (var item in allItems)
                                    {
                                        if (item.BarItemId == si.BarItemId)
                                        {
                                            <option value="@item.BarItemId" selected="selected">@item.Name (@item.Price.ToString("0.00") zł)</option>
                                        }
                                        else
                                        {
                                            <option value="@item.BarItemId">@item.Name (@item.Price.ToString("0.00") zł)</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-3">
                                <input type="number" name="quantities" value="@si.Quantity" min="1" max="20"
                                       class="form-control form-control-sm" />
                            </div>
                            <div class="col-2">
                                <button type="button" class="btn btn-sm btn-outline-danger remove-row w-100">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                    }
                </div>

                <template id="rowTpl">
                    <div class="row g-2 mb-2 item-row align-items-center">
                        <div class="col-7">
                            <select name="itemIds" class="form-select form-select-sm">
                                <option value="0">- wybierz produkt -</option>
                                @foreach (var item in allItems)
                                {
                                    <option value="@item.BarItemId">@item.Name (@item.Price.ToString("0.00") zł)</option>
                                }
                            </select>
                        </div>
                        <div class="col-3">
                            <input type="number" name="quantities" value="1" min="1" max="20"
                                   class="form-control form-control-sm" />
                        </div>
                        <div class="col-2">
                            <button type="button" class="btn btn-sm btn-outline-danger remove-row w-100">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </div>
                </template>

                <div class="d-flex gap-2 mt-3">
                    <button type="submit" class="btn btn-red"><i class="bi bi-save me-1"></i> Zapisz</button>
                    <a asp-area="Admin" asp-controller="BarItems" asp-action="Index" class="btn btn-outline-secondary">Anuluj</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    var tpl = document.getElementById('rowTpl');
    var container = document.getElementById('itemRows');

    function wireRemove(row) {
        row.querySelector('.remove-row').addEventListener('click', function () {
            this.closest('.item-row').remove();
        });
    }

    container.querySelectorAll('.item-row').forEach(wireRemove);

    document.getElementById('addRow').addEventListener('click', function () {
        var clone = tpl.content.cloneNode(true);
        wireRemove(clone.querySelector('.item-row'));
        container.appendChild(clone);
    });

    document.getElementById('imgInput').addEventListener('change', function () {
        var f = this.files[0];
        if (!f) return;
        var preview = document.getElementById('imgPreview');
        var wrap = document.getElementById('imgPreviewWrap');
        var r = new FileReader();
        r.onload = function (e) {
            preview.src = e.target.result;
            if (wrap) wrap.style.display = '';
        };
        r.readAsDataURL(f);
    });
})();
</script>
}
