@model IEnumerable<Reservation>
@{
    ViewData["Title"] = "Reservations";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <form method="get" class="d-flex gap-2" style="max-width:400px;">
        <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search code or user..." />
        <button class="btn btn-outline-secondary"><i class="bi bi-search"></i></button>
    </form>
</div>
<div class="table-responsive">
    <table class="table table-dark-cinema align-middle">
        <thead><tr><th>Code</th><th>User</th><th>Movie</th><th>Date</th><th>Seat</th><th>Status</th><th class="text-end">Actions</th></tr></thead>
        <tbody>
            @foreach (var r in Model)
            {
                <tr>
                    <td><strong>@r.ReservationCode</strong></td>
                    <td>@r.AppUser?.FullName</td>
                    <td>@r.Screening.Movie.Title</td>
                    <td>@r.Screening.StartTime.ToString("MMM d · HH:mm")</td>
                    <td>@r.SeatNumber</td>
                    <td><span class="badge-status @r.Status.ToString().ToLower()">@r.Status</span></td>
                    <td class="text-end"><a asp-action="Details" asp-route-id="@r.ReservationId" class="btn btn-sm btn-outline-secondary"><i class="bi bi-eye"></i></a></td>
                </tr>
            }
        </tbody>
    </table>
</div>