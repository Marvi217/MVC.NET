@model Screening
@{
    ViewData["Title"] = $"Screening � {Model.Movie?.Title}";
}
<div class="card p-3 mb-3">
    <h3>@Model.Movie?.Title</h3>
    <table class="table table-dark-cinema mb-0">
        <tr><th>Start</th><td>@Model.StartTime.ToString("yyyy-MM-dd HH:mm")</td></tr>
        <tr><th>Cinema</th><td>@Model.Hall.Cinema?.Name</td></tr>
        <tr><th>Hall</th><td>#@Model.Hall.Number � <span class="badge-hall @Model.Hall.Type.ToString().ToLower()">@(Model.Hall.Type switch { CinePlex.Models.HallType.FourD => "4DX", CinePlex.Models.HallType.ThreeD => "3D", CinePlex.Models.HallType.IMAX => "IMAX", _ => "2D" })</span></td></tr>
        <tr><th>Audio</th><td><span class="badge-audio">@Model.AudioVersion</span></td></tr>
        <tr><th>Price</th><td>@Model.TicketPrice.ToString("0.00") z�</td></tr>
        <tr><th>Booked / Capacity</th><td>@((Model.Hall.Capacity - Model.AvailableSeats))/@Model.Hall.Capacity</td></tr>
    </table>
</div>
<div class="card p-3">
    <h5>Reservations</h5>
    <table class="table table-dark-cinema mb-0">
        <thead><tr><th>Code</th><th>Seat</th><th>User</th><th>Status</th><th>When</th></tr></thead>
        <tbody>
            @foreach (var r in Model.Reservations ?? new List<Reservation>())
            {
                <tr>
                    <td>@r.ReservationCode</td>
                    <td>@r.SeatNumber</td>
                    <td>@r.AppUser?.FullName</td>
                    <td><span class="badge-status @r.Status.ToString().ToLower()">@r.Status</span></td>
                    <td>@r.PurchaseDate.ToString("MMM d HH:mm")</td>
                </tr>
            }
        </tbody>
    </table>
</div>
<div class="mt-3 d-flex gap-2">
    <a asp-action="Edit" asp-route-id="@Model.ScreeningId" class="btn btn-outline-warning"><i class="bi bi-pencil"></i> Edit</a>
    <a asp-action="Delete" asp-route-id="@Model.ScreeningId" class="btn btn-outline-danger"><i class="bi bi-trash"></i> Delete</a>
    <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
</div>