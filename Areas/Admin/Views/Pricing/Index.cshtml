@model IEnumerable<CinePlex.Models.HallTypePricing>
@using CinePlex.Models
@{
    ViewData["Title"] = "Cennik";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    var typeLabels = new Dictionary<HallType, string>
    {
        [HallType.Standard] = "Standard",
        [HallType.ThreeD]   = "3D",
        [HallType.IMAX]     = "IMAX",
        [HallType.FourD]    = "4DX",
    };
}

<div class="d-flex justify-content-between align-items-center mb-3 mt-2">
    <h5 class="mb-0">Ceny biletów wg typu sali</h5>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success py-2">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger py-2">@TempData["Error"]</div>
}

<div class="card">
    <table class="table table-dark-cinema mb-0">
        <thead>
            <tr>
                <th>Typ sali</th>
                <th>Cena bazowa (zł)</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td class="fw-600">@typeLabels.GetValueOrDefault(p.HallType, p.HallType.ToString())</td>
                    <td>
                        <form asp-area="Admin" asp-controller="Pricing" asp-action="Edit" method="post" class="d-flex gap-2 align-items-center">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@p.Id" />
                            <input type="number" name="defaultPrice" value="@p.DefaultPrice.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)"
                                   step="0.01" min="0.01" class="form-control form-control-sm" style="width:110px;" />
                            <button type="submit" class="btn btn-sm btn-red">Zapisz</button>
                        </form>
                    </td>
                    <td class="text-muted small">
                        Mnożniki rzędów stosowane przy kasie (× cena bazowa)
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
