@model Director
@{
    ViewData["Title"] = Model.FullName;
}
<div class="card p-3">
    <h3>@Model.FullName</h3>
    <table class="table table-dark-cinema mb-0">
        <tr><th>Nationality</th><td>@Model.Nationality</td></tr>
        <tr><th>Biography</th><td>@Model.Biography</td></tr>
    </table>
</div>
<div class="mt-3 d-flex gap-2">
    <a asp-action="Edit" asp-route-id="@Model.DirectorId" class="btn btn-outline-warning"><i class="bi bi-pencil"></i> Edit</a>
    <a asp-action="Delete" asp-route-id="@Model.DirectorId" class="btn btn-outline-danger"><i class="bi bi-trash"></i> Delete</a>
    <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
</div>