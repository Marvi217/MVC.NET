@model IEnumerable<CinePlex.Models.Marathon>
@{
    ViewData["Title"] = "Maratony";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Maratony <span class="text-muted fw-normal" style="font-size:.9rem;">(@Model.Count())</span></h4>
    <a asp-action="Create" class="btn btn-red btn-sm"><i class="bi bi-plus-circle me-1"></i> Nowy maraton</a>
</div>

@if (!Model.Any())
{
    <div class="text-center text-muted py-5">
        <i class="bi bi-collection-play" style="font-size:2.5rem;display:block;margin-bottom:.75rem;"></i>
        Brak maratonów. <a asp-action="Create">Dodaj pierwszy.</a>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Nazwa</th>
                    <th>Kino / Sala</th>
                    <th>Start</th>
                    <th>Filmów</th>
                    <th>Cena</th>
                    <th>Rezerwacje</th>
                    <th>Aktywny</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var m in Model)
                {
                    <tr>
                        <td><a asp-action="Details" asp-route-id="@m.MarathonId" class="fw-semibold text-decoration-none">@m.Name</a></td>
                        <td>@m.Hall?.Cinema?.Name — Sala @m.Hall?.Number</td>
                        <td>@m.StartTime.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>@m.Screenings.Count</td>
                        <td>@m.Price.ToString("C", new System.Globalization.CultureInfo("pl-PL"))</td>
                        <td>@m.Reservations.Count(r => r.Status != CinePlex.Models.ReservationStatus.Cancelled)</td>
                        <td>
                            <form asp-action="ToggleActive" asp-route-id="@m.MarathonId" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm @(m.IsActive ? "btn-success" : "btn-outline-secondary")">
                                    @(m.IsActive ? "Tak" : "Nie")
                                </button>
                            </form>
                        </td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@m.MarathonId" class="btn btn-sm btn-outline-secondary me-1"><i class="bi bi-pencil"></i></a>
                            <a asp-action="Delete" asp-route-id="@m.MarathonId" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
