@model CinePlex.Models.Marathon
@{
    ViewData["Title"] = "Usuń maraton";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    bool hasActive = Model.Reservations.Any(r => r.Status != CinePlex.Models.ReservationStatus.Cancelled);
}

<div class="card p-4" style="max-width:600px;">
    <h5 class="mb-3 text-danger">Usuń maraton</h5>

    <p>Czy na pewno chcesz usunąć maraton <strong>@Model.Name</strong>?</p>
    <ul class="small text-muted mb-3">
        <li>Seanse: @Model.Screenings.Count</li>
        <li>Rezerwacje aktywne: @Model.Reservations.Count(r => r.Status != CinePlex.Models.ReservationStatus.Cancelled)</li>
    </ul>

    @if (hasActive)
    {
        <div class="alert alert-warning">Nie można usunąć — istnieją aktywne rezerwacje.</div>
        <a asp-action="Index" class="btn btn-outline-secondary">Wróć</a>
    }
    else
    {
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">Usuń</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Anuluj</a>
            </div>
        </form>
    }
</div>
