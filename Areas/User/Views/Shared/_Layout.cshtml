@using Microsoft.AspNetCore.Http
@{
    var ctrl = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();
    var selCinemaId = Context.Session.GetInt32("SelectedCinemaId");
    var fourDxUrl = selCinemaId.HasValue
        ? $"/Screenings?cinemaId={selCinemaId}&hallType=FourD"
        : "/Screenings?hallType=FourD";

    string OB(string c, string? a = null)
    {
        if (a != null) return ctrl == c && action == a ? "active-bar" : "";
        return ctrl == c ? "active-bar" : "";
    }
}
<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CinePlex</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    
    <header class="topbar">
        <div class="topbar-inner">
            <a class="topbar-brand" asp-controller="Home" asp-action="Index">
                <span>CINE</span><span class="brand-accent">PLEX</span>
            </a>

            @await Component.InvokeAsync("NavCinemaPicker")

            <div class="topbar-right">
                <form asp-controller="Search" asp-action="Index" method="get" class="topbar-search d-flex">
                    <div class="input-group input-group-sm">
                        <input type="text" name="q" class="form-control" placeholder="Szukaj...">
                        <button type="submit" class="btn"><i class="bi bi-search"></i></button>
                    </div>
                </form>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    var name = User.Identity.Name ?? "U";
                    var initials = string.Concat(name.Split(' ', '@').Where(p => p.Length > 0).Take(2).Select(p => p[0])).ToUpper();
                    <div class="dropdown">
                        <a class="topbar-link dropdown-toggle d-flex align-items-center gap-2" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <span class="avatar-circle">@initials</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end">
                            <li><a class="dropdown-item" asp-controller="Reservations" asp-action="Index"><i class="bi bi-ticket-perforated me-2"></i>Moje rezerwacje</a></li>
                            <li><hr class="dropdown-divider" /></li>
                            <li>
                                <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                    <button type="submit" class="dropdown-item"><i class="bi bi-box-arrow-right me-2"></i>Wyloguj</button>
                                </form>
                            </li>
                        </ul>
                    </div>
                }
                else
                {
                    <a class="topbar-link topbar-login-btn" asp-controller="Account" asp-action="Login">Logowanie</a>
                    <a class="btn btn-orange btn-sm topbar-reg-btn" asp-controller="Account" asp-action="Register">Rejestracja</a>
                }
            </div>
        </div>
    </header>

    
    <nav class="orangebar">
        <div class="orangebar-inner">
            <a class="orangebar-link @OB("Screenings")"
               href="@(selCinemaId.HasValue ? $"/Screenings?cinemaId={selCinemaId}" : "/Screenings")">REPERTUAR</a>
            <a class="orangebar-link @OB("ComingSoon")" asp-controller="ComingSoon" asp-action="Index">WKRÓTCE</a>
            <a class="orangebar-link @OB("Marathons")" asp-controller="Marathons" asp-action="Index">MARATONY</a>
            <a class="orangebar-link @OB("Home","Bar")" asp-controller="Home" asp-action="Bar">BAR</a>
            <a class="orangebar-link orangebar-4dx" href="@fourDxUrl">4DX</a>
            <a class="orangebar-link @OB("Reservations","Check")" asp-controller="Reservations" asp-action="Check">REZERWACJA</a>
            @if (User.IsInRole("Admin"))
            {
                <a class="orangebar-link orangebar-admin" asp-area="Admin" asp-controller="Statistics" asp-action="Index">ADMIN</a>
            }
        </div>
    </nav>

    <main class="content-main">
        @if (TempData["Success"] != null)
        {
            <div class="container mt-3">
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="container mt-3">
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        }
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container">
            <div class="row gy-3">
                <div class="col-md-4">
                    <h5 class="mb-2">CINEPLEX</h5>
                    <p class="mb-0">Your cinema. Your way. Experience movies like never before.</p>
                </div>
                <div class="col-md-4">
                    <h6 class="text-uppercase mb-2">Odkryj</h6>
                    <ul class="list-unstyled mb-0">
                        <li><a asp-controller="Screenings" asp-action="Index">Repertuar</a></li>
                        <li><a asp-controller="ComingSoon" asp-action="Index">Wkrótce w kinach</a></li>
                        <li><a asp-controller="Cinemas" asp-action="Index">Kina</a></li>
                        <li><a asp-controller="Home" asp-action="Bar">Bar</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h6 class="text-uppercase mb-2">Konto</h6>
                    <ul class="list-unstyled mb-0">
                        <li><a asp-controller="Reservations" asp-action="Index">Moje rezerwacje</a></li>
                        <li><a asp-controller="Reservations" asp-action="Check">Sprawdź rezerwację</a></li>
                    </ul>
                </div>
            </div>
            <hr class="my-4" />
            <div class="text-center small">&copy; @DateTime.Now.Year CinePlex. All rights reserved.</div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@@8.0.0/dist/browser/signalr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
