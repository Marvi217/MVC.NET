@model Reservation
@{
    ViewData["Title"] = "Reservation Found";
}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-9">
            <a asp-action="Check" class="text-muted small d-inline-block mb-3"><i class="bi bi-arrow-left"></i> Search another</a>
            @if (Model == null)
            {
                <div class="card p-4 text-center">
                    <i class="bi bi-exclamation-circle" style="font-size:3rem;color:var(--red);"></i>
                    <h3 class="mt-2">Not Found</h3>
                    <p class="text-muted">No reservation matches that code.</p>
                </div>
            }
            else
            {
                <div class="ticket-card p-4">
                    <div class="row g-4">
                        <div class="col-md-7">
                            <h6 class="text-muted text-uppercase small">Movie</h6>
                            <h3>@Model.Screening.Movie.Title</h3>
                            <div class="d-flex gap-2 mb-3">
                                <span class="badge-genre">@Model.Screening.Movie.Genre</span>
                                <span class="badge-age">@Model.Screening.Movie.AgeRating</span>
                            </div>
                        </div>
                        <div class="col-md-5 ticket-tear ps-md-4">
                            <h6 class="text-muted text-uppercase small">Booking</h6>
                            <ul class="list-unstyled small">
                                <li class="mb-2"><i class="bi bi-calendar3 text-muted"></i> <strong>@Model.Screening.StartTime.ToString("dddd, MMM d · HH:mm")</strong></li>
                                <li class="mb-2"><i class="bi bi-building text-muted"></i> @Model.Screening.Hall.Cinema.Name</li>
                                <li class="mb-2"><i class="bi bi-grid-3x3 text-muted"></i> Hall #@Model.Screening.Hall.Number · <span class="badge-hall @Model.Screening.Hall.Type.ToString().ToLower()">@(Model.Screening.Hall.Type switch { CinePlex.Models.HallType.FourD => "4DX", CinePlex.Models.HallType.ThreeD => "3D", CinePlex.Models.HallType.IMAX => "IMAX", _ => "2D" })</span></li>
                                <li><i class="bi bi-bookmark text-muted"></i> Seat <strong>@Model.SeatNumber</strong></li>
                            </ul>
                            <span class="badge-status @Model.Status.ToString().ToLower()">@Model.Status</span>
                        </div>
                    </div>
                    <hr class="ticket-divider" />
                    <div class="text-center">
                        <div class="text-muted text-uppercase small mb-2">Reservation Code</div>
                        <div class="reservation-code">@Model.ReservationCode</div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>