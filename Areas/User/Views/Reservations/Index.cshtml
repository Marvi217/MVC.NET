@model IEnumerable<CinePlex.ViewModels.BookingHistoryItem>
@{
    ViewData["Title"] = "My Reservations";
    var now = DateTime.Now;
    var upcoming = Model.Where(i => i.EventDate >= now).ToList();
    var past = Model.Where(i => i.EventDate < now).ToList();
}
<div class="container py-4">
    <h1 class="mb-4">My Reservations</h1>

    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-ticket-perforated" style="font-size:3rem;"></i>
            <p class="mt-3">You haven't booked anything yet.</p>
            <a asp-controller="Movies" asp-action="Index" class="btn btn-red mt-2">Browse Movies</a>
        </div>
    }
    else
    {
        @if (upcoming.Any())
        {
            <h4 class="mb-3">Upcoming</h4>
            @await Html.PartialAsync("_ReservationTable", upcoming)
        }
        @if (past.Any())
        {
            <hr class="my-4" style="border-color:var(--border);" />
            <h4 class="mb-3 text-muted">Past</h4>
            @await Html.PartialAsync("_ReservationTable", past)
        }
    }
</div>
