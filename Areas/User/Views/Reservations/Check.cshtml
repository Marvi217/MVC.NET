@{
    ViewData["Title"] = "Check Reservation";
}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card p-4 text-center">
                <i class="bi bi-ticket-perforated" style="font-size:3rem;color:var(--red);"></i>
                <h2 class="mt-2 mb-1">Check Reservation</h2>
                <p class="text-muted">Enter your 8-character reservation code.</p>
                <form asp-action="CheckResult" method="get" class="mt-3">
                    <input type="text" name="code" maxlength="8" required
                           class="form-control form-control-lg text-center"
                           style="font-family:'JetBrains Mono',monospace; font-size:2rem; letter-spacing:.5rem; text-transform:uppercase;"
                           placeholder="XXXXXXXX" />
                    <button type="submit" class="btn btn-red btn-lg w-100 mt-3"><i class="bi bi-search"></i> Search</button>
                </form>
            </div>
        </div>
    </div>
</div>