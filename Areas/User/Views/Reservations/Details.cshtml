@model Reservation
@using CinePlex.Models
@{
    ViewData["Title"] = $"Rezerwacja {Model.ReservationCode}";
    var canCancel = Model.Status == ReservationStatus.Confirmed && Model.Screening.StartTime > DateTime.Now.AddHours(1);
    var layout    = HallLayoutConfig.FromJson(Model.Screening.Hall?.LayoutJson);
    var seatLabel = layout?.GetSeatLabel(Model.SeatNumber) ?? Model.SeatNumber.ToString();
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-9">
            <a asp-action="Index" class="text-muted small d-inline-block mb-3 back-link-anim">
                <i class="bi bi-arrow-left"></i> Moje rezerwacje
            </a>
            <div class="ticket-card p-4 ticket-entrance">
                <div class="row g-4">
                    <div class="col-md-7">
                        <h6 class="text-muted text-uppercase small">Film</h6>
                        <h3>@Model.Screening.Movie.Title</h3>
                        <div class="d-flex gap-2 mb-3">
                            <span class="badge-genre">@Model.Screening.Movie.Genre</span>
                            <span class="badge-age">@Model.Screening.Movie.AgeRating</span>
                            <span class="duration-pill"><i class="bi bi-clock"></i> @Model.Screening.Movie.Duration min</span>
                        </div>
                        <p class="text-muted small">@Model.Screening.Movie.Description</p>
                    </div>
                    <div class="col-md-5 ticket-tear ps-md-4">
                        <h6 class="text-muted text-uppercase small">Szczeg&oacute;&lstrok;y</h6>
                        <ul class="list-unstyled small">
                            <li class="mb-2"><i class="bi bi-calendar3 text-muted"></i> <strong>@Model.Screening.StartTime.ToString("dddd, d MMM")</strong></li>
                            <li class="mb-2"><i class="bi bi-clock text-muted"></i> <strong>@Model.Screening.StartTime.ToString("HH:mm")</strong></li>
                            <li class="mb-2"><i class="bi bi-building text-muted"></i> @Model.Screening.Hall.Cinema.Name</li>
                            <li class="mb-2">
                                <i class="bi bi-grid-3x3 text-muted"></i>
                                Sala #@Model.Screening.Hall.Number
                                &middot;
                                <span class="badge-hall @Model.Screening.Hall.Type.ToString().ToLower()">@(Model.Screening.Hall.Type switch { CinePlex.Models.HallType.FourD => "4DX", CinePlex.Models.HallType.ThreeD => "3D", CinePlex.Models.HallType.IMAX => "IMAX", _ => "2D" })</span>
                            </li>
                            <li class="mb-2"><i class="bi bi-bookmark text-muted"></i> Miejsce <strong>@seatLabel</strong></li>
                            <li><i class="bi bi-cash text-muted"></i> <strong>@Model.PricePaid.ToString("0.00") z&#322;</strong></li>
                        </ul>
                        <div class="mt-3">
                            <span class="badge-status @Model.Status.ToString().ToLower()" style="font-size:.9rem;">@Model.Status</span>
                        </div>
                    </div>
                </div>

                <hr class="ticket-divider" />

                <div class="text-center">
                    <div id="qrDiv" class="mx-auto mb-3" style="width:160px;height:160px;background:#fff;border-radius:10px;overflow:hidden;display:flex;align-items:center;justify-content:center;"></div>
                    <div class="text-muted text-uppercase small mb-2" style="letter-spacing:2px;">Kod rezerwacji</div>
                    <div class="reservation-code">@Model.ReservationCode</div>
                    <p class="text-muted small mt-2 mb-0">Zarezerwowano @Model.PurchaseDate.ToString("d MMM yyyy, HH:mm")</p>
                </div>

                @if (canCancel)
                {
                    <hr class="ticket-divider" />
                    <form asp-action="Cancel" asp-route-id="@Model.ReservationId" method="post"
                          class="text-center" onsubmit="return confirm('Anulowa&#263; t&#281; rezerwacj&#281;?');">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-danger">
                            <i class="bi bi-x-circle"></i> Anuluj rezerwacj&#281;
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script>
new QRCode(document.getElementById('qrDiv'), {
    text: '@Model.ReservationCode',
    width: 160, height: 160,
    colorDark: '#000000', colorLight: '#ffffff',
    correctLevel: QRCode.CorrectLevel.H
});
</script>
}
