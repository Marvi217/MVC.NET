@{
    ViewData["Title"] = "Zakup biletów maratonowych";
    var marathon = ViewBag.Marathon as CinePlex.Models.Marathon;
    var seats = ViewBag.Seats as List<int> ?? new List<int>();
    var seatLabels = ViewBag.SeatLabels as List<string> ?? seats.Select(s => s.ToString()).ToList();
    var total = marathon?.Price * seats.Count ?? 0;
    var pl = new System.Globalization.CultureInfo("pl-PL");
}

<div class="container py-5" style="max-width:560px;">
    <h3 class="mb-4">Zakup biletów maratonowych</h3>

    <div class="card p-4 mb-4">
        <div class="fw-semibold fs-5 mb-2">@marathon?.Name</div>
        <div class="text-muted small mb-1"><i class="bi bi-geo-alt me-1"></i>@marathon?.Hall?.Cinema?.Name — Sala @marathon?.Hall?.Number</div>
        <div class="text-muted small mb-1"><i class="bi bi-calendar me-1"></i>@marathon?.StartTime.ToString("dd.MM.yyyy HH:mm")</div>
        <div class="text-muted small mb-1"><i class="bi bi-film me-1"></i>@marathon?.Screenings.Count filmów</div>
        <div class="text-muted small mb-3">
            <i class="bi bi-geo me-1"></i>Miejsca: <strong>@string.Join(", ", seatLabels)</strong>
            @if (seats.Count > 1)
            {
                <span class="ms-1">(@seats.Count szt.)</span>
            }
        </div>
        <div class="text-muted small mb-1">Cena za bilet: @marathon?.Price.ToString("C", pl)</div>
        <div class="fw-bold fs-4">Razem: @total.ToString("C", pl)</div>
    </div>

    <form method="post" asp-action="ProcessCheckout">
        @Html.AntiForgeryToken()
        <input type="hidden" name="marathonId" value="@marathon?.MarathonId" />
        @foreach (var s in seats)
        {
            <input type="hidden" name="seatNumbers" value="@s" />
        }

        @if (!User.Identity!.IsAuthenticated)
        {
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label class="form-label">Imię *</label>
                    <input name="firstName" class="form-control" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Nazwisko *</label>
                    <input name="lastName" class="form-control" required />
                </div>
                <div class="col-12">
                    <label class="form-label">E-mail *</label>
                    <input name="email" type="email" class="form-control" required />
                </div>
            </div>
        }

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-orange"><i class="bi bi-credit-card me-1"></i> Kup bilety</button>
            <a asp-action="Details" asp-route-id="@marathon?.MarathonId" class="btn btn-outline-secondary">Wróć</a>
        </div>
    </form>
</div>
