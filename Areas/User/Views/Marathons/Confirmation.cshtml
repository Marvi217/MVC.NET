@model List<CinePlex.Models.Reservation>
@using CinePlex.Models
@{
    ViewData["Title"] = "Rezerwacja potwierdzona";
    var first = Model.First();
    var layout = HallLayoutConfig.FromJson(first.Marathon?.Hall?.LayoutJson);
}

<style>
.ticket-stub { overflow: hidden; max-width: 480px; margin: 0 auto 2rem; }
.ticket-stub-header { padding: 1.2rem 1.5rem; display: flex; gap: 1rem; align-items: center; }
.ticket-stub-body { padding: 1.25rem 1.5rem; }
.ticket-field { margin-bottom: .8rem; }
.ticket-field-label { margin-bottom: .15rem; }
.ticket-code { padding: .35rem .75rem; display: inline-block; }
</style>

<div class="container py-5">
    <div class="text-center mb-5">
        <i class="bi bi-check-circle-fill" style="font-size:3.5rem;color:#4ade80;"></i>
        <h1 class="mt-3" style="font-family:'Bebas Neue',sans-serif;font-size:2.2rem;letter-spacing:2px;">REZERWACJA POTWIERDZONA!</h1>
        <p class="text-muted">
            Masz @Model.Count @(Model.Count == 1 ? "bilet" : Model.Count < 5 ? "bilety" : "biletów") na maraton.
            Pokaż kod QR lub numer rezerwacji przy wejściu.
        </p>
    </div>

    @for (int i = 0; i < Model.Count; i++)
    {
        var r = Model[i];
        var seatLabel = (layout?.GetSeatLabel(r.SeatNumber) is string lbl && lbl != r.SeatNumber.ToString())
            ? lbl
            : r.SeatRow + r.SeatNumber;
        var canvasId = $"qr_{i}";
        <div class="ticket-stub">
            <div class="ticket-stub-header">
                <div class="flex-grow-1 min-w-0">
                    <div style="font-family:'Bebas Neue',sans-serif;font-size:1.2rem;letter-spacing:1px;color:#fff;">
                        @r.Marathon?.Name?.ToUpper()
                    </div>
                    <div class="text-muted small mt-1">
                        <i class="bi bi-building"></i> @r.Marathon?.Hall?.Cinema?.Name · @r.Marathon?.Hall?.Cinema?.City
                    </div>
                    <div class="text-muted small">
                        <i class="bi bi-clock"></i> @r.Marathon?.StartTime.ToString("dd.MM.yyyy HH:mm")
                        &nbsp;|&nbsp; Sala #@r.Marathon?.Hall?.Number
                    </div>
                </div>
            </div>
            <div class="ticket-stub-body">
                <div class="row align-items-center g-3">
                    <div class="col">
                        <div class="ticket-field">
                            <div class="ticket-field-label">Miejsce</div>
                            <div class="ticket-seat-badge">@seatLabel</div>
                        </div>
                        <div class="ticket-field">
                            <div class="ticket-field-label">Cena</div>
                            <div class="ticket-field-value" style="color:#ffa500;">@r.PricePaid.ToString("0.00") zł</div>
                        </div>
                    </div>
                    <div class="col-auto text-center">
                        <div id="@canvasId" class="d-block mb-1" style="width:92px;height:92px;padding:6px;box-sizing:border-box;background:#fff;border-radius:8px;overflow:hidden;"></div>
                        <div style="font-size:.6rem;color:var(--text-muted);letter-spacing:.5px;">ZESKANUJ PRZY WEJŚCIU</div>
                    </div>
                </div>
                <hr class="ticket-divider" />
                <div class="ticket-field-label mb-1">Kod rezerwacji</div>
                <div class="ticket-code">@r.ReservationCode</div>
            </div>
        </div>
    }

    <div class="text-center mt-2 d-flex gap-3 justify-content-center flex-wrap">
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a asp-controller="Reservations" asp-action="Index" class="btn btn-orange">
                <i class="bi bi-ticket-perforated"></i> Moje rezerwacje
            </a>
        }
        <a asp-controller="Marathons" asp-action="Index" class="btn btn-outline-light">
            <i class="bi bi-collection-play"></i> Powrót do maratonów
        </a>
    </div>
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script>
var codes = [@Html.Raw(string.Join(",", Model.Select((r,i) => "{id:'qr_" + i + "',code:'" + r.ReservationCode + "'}"))  )];
codes.forEach(function(item) {
    new QRCode(document.getElementById(item.id), {
        text: item.code,
        width: 80, height: 80,
        colorDark: '#000000', colorLight: '#ffffff',
        correctLevel: QRCode.CorrectLevel.M
    });
});
</script>
}
