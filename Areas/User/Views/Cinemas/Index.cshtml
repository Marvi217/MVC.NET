@model IEnumerable<Cinema>
@{
    ViewData["Title"] = "Cinemas";
}

<style>
    .cinema-card-lg {
        padding: 2rem;
        position: relative;
        overflow: hidden;
        height: 100%;
        text-decoration: none;
        display: block;
    }
    .cinema-icon-wrap {
        width: 52px; height: 52px;
        display: flex; align-items: center; justify-content: center;
        margin-bottom: 1.25rem;
    }
</style>

<div class="container py-4">
    <h1 class="page-title mb-2">Our Cinemas</h1>
    <p class="text-muted mb-5">Explore our locations and find the perfect cinema near you.</p>

    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-building" style="font-size:3rem;"></i>
            <p class="mt-3">No cinemas found.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var c in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <a asp-action="Details" asp-route-id="@c.CinemaId" class="cinema-card-lg">
                        <div class="cinema-icon-wrap">
                            <i class="bi bi-building"></i>
                        </div>
                        <h4 class="mb-1">@c.Name</h4>
                        <span class="city-badge mb-3 d-inline-flex"><i class="bi bi-geo-alt me-1"></i>@c.City</span>
                        @if (!string.IsNullOrWhiteSpace(c.Address))
                        {
                            <p class="text-muted small mb-0"><i class="bi bi-map me-1"></i>@c.Address</p>
                        }
                    </a>
                </div>
            }
        </div>
    }
</div>

