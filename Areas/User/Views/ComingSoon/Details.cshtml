@model CinePlex.Models.Movie
@using CinePlex.ViewModels
@{
    ViewData["Title"] = Model.Title;
    var cast = ViewBag.Cast as List<CastMemberViewModel> ?? new List<CastMemberViewModel>();
    var embedUrl = ViewBag.EmbedUrl as string;
}

<style>
    .cs-detail-poster {
        width: 100%;
        max-width: 260px;
    }
    .cs-detail-poster-ph {
        width: 260px; height: 390px;
        display: flex; align-items: center; justify-content: center;
    }
    .cs-badge {
        display: inline-block;
        padding: .2rem .7rem;
    }
    .cast-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
        gap: 1rem;
        margin-top: .75rem;
    }
    .cast-card {
        overflow: hidden;
        text-align: center;
    }
    .cast-photo { width: 100%; aspect-ratio: 2/3; object-fit: cover; }
    .cast-photo-ph {
        width: 100%; aspect-ratio: 2/3;
        display: flex; align-items: center; justify-content: center;
    }
    .cast-info { padding: .5rem .4rem; }
    .trailer-section { margin-top: 2.5rem; }
    .trailer-section h4 { margin-bottom: 1rem; }
    .trailer-wrapper {
        position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden;
    }
    .trailer-wrapper iframe {
        position: absolute; top: 0; left: 0; width: 100%; height: 100%;
        border: 0;
    }
    .section-label { margin-bottom: .75rem; }
</style>

<div class="container py-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary mb-4">
        <i class="bi bi-arrow-left"></i> Wkrótce w kinach
    </a>

    <div class="row g-4">
        
        <div class="col-auto">
            @if (!string.IsNullOrEmpty(Model.PosterUrl))
            {
                <img src="@Model.PosterUrl" alt="@Model.Title" class="cs-detail-poster" />
            }
            else
            {
                <div class="cs-detail-poster-ph"><i class="bi bi-film"></i></div>
            }
        </div>

        
        <div class="col">
            <h1 class="cs-detail-title">@Model.Title.ToUpper()</h1>

            <div class="d-flex flex-wrap gap-2 my-3">
                <span class="cs-badge">@Model.Genre</span>
                <span class="cs-badge">@Model.Duration min</span>
                <span class="cs-badge">@Model.AgeRating</span>
                <span class="cs-badge">
                    <i class="bi bi-calendar-event"></i>
                    Premiera: @Model.ReleaseDate.ToString("dd.MM.yyyy")
                </span>
            </div>

            @if (Model.Director != null)
            {
                <p class="text-muted mb-3" style="font-size:.85rem;">
                    <i class="bi bi-camera-video"></i>
                    Reżyseria: <strong>@Model.Director.FirstName @Model.Director.LastName</strong>
                </p>
            }

            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <p class="cs-description">@Model.Description</p>
            }
        </div>
    </div>

    
    @if (cast.Any())
    {
        <div class="mt-4">
            <div class="section-label">OBSADA</div>
            <div class="cast-grid">
                @foreach (var member in cast)
                {
                    <div class="cast-card">
                        @if (!string.IsNullOrEmpty(member.ProfileUrl))
                        {
                            <img src="@member.ProfileUrl" alt="@member.Name" class="cast-photo" loading="lazy" />
                        }
                        else
                        {
                            <div class="cast-photo-ph"><i class="bi bi-person-fill"></i></div>
                        }
                        <div class="cast-info">
                            <div class="cast-name">@member.Name</div>
                            @if (!string.IsNullOrEmpty(member.Character))
                            {
                                <div class="cast-char">@member.Character</div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    
    @if (embedUrl != null)
    {
        <div class="trailer-section">
            <h4>ZWIASTUN</h4>
            <div class="trailer-wrapper">
                <iframe src="@embedUrl" allowfullscreen
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture">
                </iframe>
            </div>
        </div>
    }
</div>

