@model IEnumerable<CinePlex.Models.BarItem>
@using CinePlex.Models
@{
    ViewData["Title"] = "Bar";
    var przekaski = Model.Where(b => b.Category == BarCategory.Przekaski).ToList();
    var napoje    = Model.Where(b => b.Category == BarCategory.Napoje).ToList();
    var barSets   = (ViewBag.BarSets as IEnumerable<BarSet> ?? Enumerable.Empty<BarSet>()).ToList();
    bool hasContent = Model.Any() || barSets.Any();
}

<style>
    .bar-hero {
        position: relative;
        padding: 7rem 0 5rem;
        text-align: center;
        overflow: hidden;
    }
    .bar-hero-inner { position: relative; z-index: 1; }
    .bar-tabs-wrap {
        position: sticky;
        top: 64px;
        z-index: 100;
        padding: .8rem 0;
    }
    .bar-tabs { display: flex; gap: .5rem; justify-content: center; flex-wrap: wrap; }
    .bar-tab {
        padding: .45rem 1.5rem;
        cursor: pointer;
        white-space: nowrap;
    }
    .bar-content { padding: 3.5rem 0 5rem; }
    .bar-section { margin-bottom: 3.5rem; }
    .bar-section-head {
        display: flex;
        align-items: center;
        gap: .85rem;
        margin-bottom: 1.75rem;
    }
    .bar-section-line {
        flex: 1;
        height: 1px;
    }
    .product-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
        gap: 1.15rem;
    }
    .product-card {
        overflow: hidden;
    }
    .pc-img {
        position: relative;
        height: 210px;
        overflow: hidden;
    }
    .pc-img img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }
    .pc-img-placeholder {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .pc-body { padding: 1rem 1.15rem 1.2rem; }
    .pc-footer { display: flex; align-items: baseline; justify-content: space-between; }
    .pc-badge {
        position: absolute;
        top: 10px; right: 10px;
    }
    .pc-pills { display: flex; flex-wrap: wrap; gap: .3rem; margin-bottom: .6rem; }
    .pc-pill {
        padding: .15rem .55rem;
        white-space: nowrap;
    }
    .bar-info {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1.1rem 1.4rem;
        margin-top: 1.5rem;
    }
    .bar-empty { text-align: center; padding: 6rem 0; }
    .bar-empty i { display: block; margin-bottom: 1rem; }
</style>

<div class="bar-hero">
    <div class="bar-hero-inner container">
        <div class="bar-hero-eyebrow">Kino - Atmosfera - Smak</div>
        <h1>NASZE <em>BARY</em></h1>
        <p class="bar-hero-sub">Wyjątkowe przekąski i napoje - idealne do każdego seansu.</p>
    </div>
</div>

@if (!hasContent)
{
    <div class="bar-empty container">
        <p>Menu baru nie zostało jeszcze skonfigurowane.<br />Zaglądnij wkrótce!</p>
    </div>
}
else
{
    
    <div class="bar-tabs-wrap">
        <div class="container">
            <div class="bar-tabs">
                <button class="bar-tab active" data-filter="all">Wszystko</button>
                @if (przekaski.Any()) { <button class="bar-tab" data-filter="przekaski">Przekąski</button> }
                @if (napoje.Any())    { <button class="bar-tab" data-filter="napoje">Napoje</button> }
                @if (barSets.Any())   { <button class="bar-tab" data-filter="zestawy">Zestawy</button> }
            </div>
        </div>
    </div>

    <div class="bar-content container">

        
        @if (barSets.Any())
        {
            <div class="bar-section" data-section="zestawy">
                <div class="bar-section-head">
                    <h2 class="bar-section-title">ZESTAWY</h2>
                    <div class="bar-section-line"></div>
                </div>
                <div class="product-grid">
                    @foreach (var (set, si) in barSets.Select((s, i) => (s, i)))
                    {
                        decimal savings = set.Items.Sum(x => (x.BarItem?.Price ?? 0) * x.Quantity) - set.Price;
                        string sc = si < 3 ? $"stagger-{si + 1}" : "";
                        <div class="product-card @sc">
                            <div class="pc-img">
                                @if (!string.IsNullOrWhiteSpace(set.ImageUrl))
                                {
                                    <img src="@set.ImageUrl" alt="@set.Name" loading="lazy" />
                                }
                                else
                                {
                                    <div class="pc-img-placeholder"></div>
                                }
                                <span class="pc-badge">ZESTAW</span>
                            </div>
                            <div class="pc-body">
                                <div class="pc-name">@set.Name</div>
                                @if (!string.IsNullOrWhiteSpace(set.Description))
                                {
                                    <div class="pc-desc">@set.Description</div>
                                }
                                @if (set.Items.Any())
                                {
                                    <div class="pc-pills">
                                        @foreach (var item in set.Items)
                                        {
                                            <span class="pc-pill">@item.BarItem?.Name@(item.Quantity > 1 ? $" ×{item.Quantity}" : "")</span>
                                        }
                                    </div>
                                }
                                <div class="pc-footer">
                                    <span class="pc-price red">@set.Price.ToString("0.00")<span class="pc-price-unit">zł</span></span>
                                    @if (savings > 0)
                                    {
                                        <span class="pc-savings">−@savings.ToString("0.00") zł</span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        
        @if (przekaski.Any())
        {
            <div class="bar-section" data-section="przekaski">
                <div class="bar-section-head">
                    <h2 class="bar-section-title">PRZEKĄSKI</h2>
                    <div class="bar-section-line"></div>
                </div>
                <div class="product-grid">
                    @foreach (var (item, pi) in przekaski.Select((x, i) => (x, i)))
                    {
                        string pc = pi < 3 ? $"stagger-{pi + 1}" : "";
                        <div class="product-card @pc">
                            <div class="pc-img">
                                @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" alt="@item.Name" loading="lazy" />
                                }
                                else
                                {
                                    <div class="pc-img-placeholder"></div>
                                }
                            </div>
                            <div class="pc-body">
                                <div class="pc-name">@item.Name</div>
                                @if (!string.IsNullOrWhiteSpace(item.Description))
                                {
                                    <div class="pc-desc">@item.Description</div>
                                }
                                <div class="pc-footer">
                                    <span class="pc-price">@item.Price.ToString("0.00")<span class="pc-price-unit">zł</span></span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        
        @if (napoje.Any())
        {
            <div class="bar-section" data-section="napoje">
                <div class="bar-section-head">
                    <h2 class="bar-section-title">NAPOJE</h2>
                    <div class="bar-section-line"></div>
                </div>
                <div class="product-grid">
                    @foreach (var (item, ni) in napoje.Select((x, i) => (x, i)))
                    {
                        string nc = ni < 3 ? $"stagger-{ni + 1}" : "";
                        <div class="product-card @nc">
                            <div class="pc-img">
                                @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" alt="@item.Name" loading="lazy" />
                                }
                                else
                                {
                                    <div class="pc-img-placeholder"></div>
                                }
                            </div>
                            <div class="pc-body">
                                <div class="pc-name">@item.Name</div>
                                @if (!string.IsNullOrWhiteSpace(item.Description))
                                {
                                    <div class="pc-desc">@item.Description</div>
                                }
                                <div class="pc-footer">
                                    <span class="pc-price">@item.Price.ToString("0.00")<span class="pc-price-unit">zł</span></span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        
        <div class="bar-info">
            <i class="bi bi-clock"></i>
            <span>Bar czynny <strong>30 min przed</strong> pierwszym seansem i do <strong>30 min po</strong> jego rozpoczęciu.</span>
        </div>

    </div>
}

@section Scripts {
<script>
(function () {
    var tabs     = document.querySelectorAll('.bar-tab');
    var sections = document.querySelectorAll('[data-section]');
    tabs.forEach(function (tab) {
        tab.addEventListener('click', function () {
            tabs.forEach(function (t) { t.classList.remove('active'); });
            tab.classList.add('active');
            var filter = tab.dataset.filter;
            sections.forEach(function (sec) {
                var show = filter === 'all' || sec.dataset.section === filter;
                sec.style.display = show ? '' : 'none';
            });
        });
    });
})();
</script>
}
